{
  "name": "@ign/gdp-tools",
  "version": "0.1.0",
  "description": "Extension d'affichage des données de géodésie pour applications IGN mobile",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "ol": "^10.0.0",
    "ol-ext": "^4.0.0",
    "proj4": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/ol-ext": "npm:@siedlerchr/types-ol-ext@^3.6.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ol": "^10.9.0",
    "ol-ext": "^4.0.38",
    "proj4": "^2.20.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "~5.9.3",
    "vite": "^8.0.12"
  }
}
